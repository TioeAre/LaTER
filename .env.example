# Optional OpenAI-compatible endpoint for data construction or GPT-based judging.
OPENAI_BASE_URL=
OPENAI_API_KEY=
STAGE1_OPENAI_BASE_URL=
JUDGE_OPENAI_BASE_URL=

# Default model and experiment settings.
BASE_MODEL_NAME=
LLM_MODEL_NAME=qwen3_32b
CONDA_ENV=later
DATASET_NAME=

# Optional dataset overrides. Values can be Hugging Face dataset ids or local paths.
DATASET_GSM8K=openai/gsm8k
DATASET_GSM8K_CONFIG=main
DATASET_AIME2024=HuggingFaceH4/aime_2024
DATASET_AIME2025=math-ai/AIME_2025
DATASET_MATH500=HuggingFaceH4/MATH-500
DATASET_GPQA_DIAMOND=Idavidrein/gpqa
DATASET_GPQA_DIAMOND_CONFIG=gpqa_diamond
DATASET_ARC=ai2_arc
DATASET_COMMONSENSE_QA=tau/commonsense_qa
DATASET_MBPPPLUS=evalplus/mbppplus
DATASET_HUMANEVALPLUS=evalplus/humanevalplus

# Internal or custom datasets are not bundled. Set these only if you have the data.
DATASET_PROSQA=
DATASET_DOLCI_THINK_SFT_32B_SAMPLED=
MEDQA_DATA_FILE=./data/medqa.json
DEFAULT_DISTILLED_REASONING_PATH=./data/latent_reasoning_distill/distilled_latent_reasoning.jsonl

# Output locations.
ENTROPY_VIZ_DIR=./results
